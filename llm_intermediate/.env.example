# Copy this file to .env in the same folder (llm_intermediate/) and adjust.
# Loaded automatically when you run: python llm.py
# Requires: pip install python-dotenv (listed in requirements.txt)

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_S=300

# Second retrieval pass for high-rated factors; set 0 for single-pass only
RAG_AGENTIC=1

# Extra Ollama JSON merge when RAG is off (adds latency); 0 = off (default)
USE_LLM_JSON=0

GROQ_API_KEY=your_key_here